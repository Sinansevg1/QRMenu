
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">QR Kod İşlemleri</h4>
        <div class="row">
            <!-- SOL: QR OLUŞTUR -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">QR Kod Oluştur</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-action="Index" asp-controller="QRCode" enctype="multipart/form-data">
                            <div class="form-group">
                                <input type="text" name="value" class="form-control" placeholder="QR kod içeriğini girin" />
                            </div>
                            <button type="submit" class="btn btn-primary btn-block">QR Kod Oluştur</button>
                        </form>
                        @if (ViewBag.QRCodeImage != null)
                        {
                            <div class="text-center mt-3">
                                <img src="@ViewBag.QRCodeImage" alt="QR Kod" style="width:300px;height:300px;" />
                            </div>
                        }
                    </div>
                </div>
            </div>
            <!-- SAĞ: QR ÇÖZ -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">QR Kod Oku</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-action="Index" asp-controller="QRCode" enctype="multipart/form-data">
                            <div class="form-group">
                                <input type="file" name="qrImage" class="form-control" accept="image/*" />
                            </div>
                            <button type="submit" class="btn btn-success btn-block">QR Kodu Çöz</button>
                        </form>
                        @if (ViewBag.DecodedText != null)
                        {
                            <div class="alert alert-success mt-3 mb-0">
                                <h5 class="mb-2">QR Kod İçeriği:</h5>
                                <hr />
                                <strong>@ViewBag.DecodedText</strong>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>